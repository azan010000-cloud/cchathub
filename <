<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@drawable/glass_card_bg"
    android:layout_marginBottom="8dp"
    android:padding="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_status_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#222232"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_camera"
            android:padding="12dp" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_item_status_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Aria Vance"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cv_status_avatar"
        app:layout_constraintTop_toTopOf="@id/cv_status_avatar" />

    <TextView
        android:id="@+id/tv_item_status_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="2 hours ago"
        android:textColor="#94A3B8"
        android:textSize="13sp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cv_status_avatar"
        app:layout_constraintTop_toBottomOf="@id/tv_item_status_name" />

</androidx.constraintlayout.widget.ConstraintLayout>