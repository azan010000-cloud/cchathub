<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B">

    <!-- Progress Bar -->
    <View
        android:id="@+id/status_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#00F5D4"
        android:layout_marginTop="16dp"
        android:layout_horizontalWeight="1"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- User Info -->
    <TextView
        android:id="@+id/tv_status_viewer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aria Vance"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/status_progress_bar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Status Content -->
    <TextView
        android:id="@+id/tv_status_viewer_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Designing the future..."
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>