    // --- DATA MODELS ---
    public static class User {
        public String uid, name, username, phone, email, bio, onlineStatus, lastSeen;
        public User(String uid, String name, String username, String phone, String email, String bio, String onlineStatus, String lastSeen) {
            this.uid = uid; this.name = name; this.username = username; this.phone = phone;
            this.email = email; this.bio = bio; this.onlineStatus = onlineStatus; this.lastSeen = lastSeen;
        }
    }

    public static class Message {
        public String senderId, text, timestamp;
        public boolean isIncoming;
        public Message(String senderId, String text, String timestamp, boolean isIncoming) {
            this.senderId = senderId; this.text = text; this.timestamp = timestamp; this.isIncoming = isIncoming;
        }
    }

    public static class Chat {
        public String chatId, chatName;
        public boolean isGroup;
        public List<Message> messages = new ArrayList<>();
        public Chat(String chatId, String chatName, boolean isGroup) {
            this.chatId = chatId; this.chatName = chatName; this.isGroup = isGroup;
        }
    }

    public static class CallLog {
        public String callerName, callType, timestamp;
        public boolean isVideo, isMissed;
        public CallLog(String callerName, String callType, String timestamp, boolean isVideo, boolean isMissed) {
            this.callerName = callerName; this.callType = callType; this.timestamp = timestamp; this.isVideo = isVideo; this.isMissed = isMissed;
        }
    }

    public static class StatusUpdate {
        public String userName, statusText, timestamp;
        public StatusUpdate(String userName, String statusText, String timestamp) {
            this.userName = userName; this.statusText = statusText; this.timestamp = timestamp;
        }
    }

    // --- RECYCLERVIEW ADAPTERS ---
    private class ChatsAdapter extends RecyclerView.Adapter<ChatsAdapter.ViewHolder> {
        private final List<Chat> list;
        private final OnChatClickListener listener;

        public interface OnChatClickListener { void onChatClick(Chat chat); }

        public ChatsAdapter(List<Chat> list, OnChatClickListener listener) {
            this.list = list; this.listener = listener;
        }

        @NonNull
        @Override
        public ViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
            View v = LayoutInflater.from(parent.getContext()).inflate(R.layout.item_chat, parent, false);
            return new ViewHolder(v);
        }

        @Override
        public void onBindViewHolder(@NonNull ViewHolder holder, int position) {
            Chat chat = list[position];
            holder.tvName.setText(chat.chatName);
            if (!chat.messages.isEmpty()) {
                holder.tvLastMsg.setText(chat.messages.get(chat.messages.size() - 1).text);
                holder.tvTime.setText(chat.messages.get(chat.messages.size() - 1).timestamp);
            } else {
                holder.tvLastMsg.setText("No messages yet");
                holder.tvTime.setText("");
            }
            holder.itemView.setOnClickListener(v -> listener.onChatClick(chat));
        }

        @Override
        public int getItemCount() { return list.size(); }

        class ViewHolder extends RecyclerView.ViewHolder {
            TextView tvName, tvLastMsg, tvTime;
            ViewHolder(View v) {
                super(v);
                tvName = v.findViewById(R.id.tv_item_chat_name);
                tvLastMsg = v.findViewById(R.id.tv_item_chat_last_msg);
                tvTime = v.findViewById(R.id.tv_item_chat_time);
            }
        }
    }

