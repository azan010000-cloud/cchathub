    private void checkAuth() {
        isLoggedIn = AppController.getInstance().getBoolean("is_logged_in", false);
        if (!isLoggedIn) {
            topBar.setVisibility(View.GONE);
            bottomNavigation.setVisibility(View.GONE);
            showLoginScreen();
        } else {
            String userJson = AppController.getInstance().getString("current_user", "");
            if (!userJson.isEmpty()) {
                currentUser = AppController.getInstance().getGson().fromJson(userJson, User.class);
                showHomeScreen();
            } else {
                showLoginScreen();
            }
        }
    }

    private void setupNavigation() {
        tabChats.setOnClickListener(v -> switchTab("chats"));
        tabFriends.setOnClickListener(v -> switchTab("friends"));
