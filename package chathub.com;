        tabProfile.setOnClickListener(v -> switchTab("profile"));
    }

    private void switchTab(String tab) {
        currentTab = tab;
        resetTabColors();
        topBar.setVisibility(View.VISIBLE);
        bottomNavigation.setVisibility(View.VISIBLE);

        switch (tab) {
            case "chats":
                iconChats.setColorFilter(Color.parseColor("#A855F7"));
                textChats.setTextColor(Color.parseColor("#A855F7"));
                appLogo.setText("ChatHub");
                btnHeaderAction.setImageResource(android.R.drawable.ic_menu_add);
                btnHeaderAction.setOnClickListener(v -> showGroupCreationDialog());
                showChatsFragment();
                break;
            case "friends":
                iconFriends.setColorFilter(Color.parseColor("#A855F7"));
                textFriends.setTextColor(Color.parseColor("#A855F7"));
                appLogo.setText("Friends");
                btnHeaderAction.setImageResource(android.R.drawable.ic_menu_add);
                btnHeaderAction.setOnClickListener(v -> showAddFriendDialog());
                showFriendsFragment();
                break;
            case "status":
                iconStatus.setColorFilter(Color.parseColor("#A855F7"));
                textStatus.setTextColor(Color.parseColor("#A855F7"));
                appLogo.setText("Status Updates");
                btnHeaderAction.setImageResource(android.R.drawable.ic_menu_camera);
                btnHeaderAction.setOnClickListener(v -> createNewStatus());
                showStatusFragment();
                break;
            case "calls":
                iconCalls.setColorFilter(Color.parseColor("#A855F7"));
                textCalls.setTextColor(Color.parseColor("#A855F7"));
                appLogo.setText("Call History");
                btnHeaderAction.setImageResource(android.R.drawable.ic_menu_call);
                btnHeaderAction.setOnClickListener(v -> initiateQuickCall());
                showCallsFragment();
                break;
            case "profile":
                iconProfile.setColorFilter(Color.parseColor("#A855F7"));
                textProfile.setTextColor(Color.parseColor("#A855F7"));
                appLogo.setText("My Profile");
                btnHeaderAction.setImageResource(android.R.drawable.ic_menu_preferences);
                btnHeaderAction.setOnClickListener(v -> showSettingsDialog());
                showProfileFragment();
                break;
        }
    }

