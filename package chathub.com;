    // --- INDIVIDUAL CHAT SCREEN ---
    private void showChatDetailScreen(Chat chat) {
        topBar.setVisibility(View.GONE);
        bottomNavigation.setVisibility(View.GONE);

        fragmentContainer.removeAllViews();
        View view = LayoutInflater.from(this).inflate(R.layout.screen_chat_detail, fragmentContainer, false);

        TextView tvChatName = view.findViewById(R.id.tv_detail_chat_name);
        ImageView btnBack = view.findViewById(R.id.btn_chat_back);
        ImageView btnVoiceCall = view.findViewById(R.id.btn_voice_call);
        ImageView btnVideoCall = view.findViewById(R.id.btn_video_call);
        RecyclerView rvMessages = view.findViewById(R.id.rv_messages);
        EditText etMessageInput = view.findViewById(R.id.et_message_input);
        ImageView btnSendMessage = view.findViewById(R.id.btn_send_message);
        TextView tvTypingIndicator = view.findViewById(R.id.tv_typing_indicator);

        tvChatName.setText(chat.chatName);

        rvMessages.setLayoutManager(new LinearLayoutManager(this));
        MessagesAdapter adapter = new MessagesAdapter(chat.messages);
        rvMessages.setAdapter(adapter);
        rvMessages.scrollToPosition(chat.messages.size() - 1);

        btnBack.setOnClickListener(v -> {
            topBar.setVisibility(View.getSystemUiVisibility());
            switchTab("chats");
        });

        btnVoiceCall.setOnClickListener(v -> startVideoCall(chat.chatName, false));
        btnVideoCall.setOnClickListener(v -> startVideoCall(chat.chatName, true));

        btnSendMessage.setOnClickListener(v -> {
            String text = etMessageInput.getText().toString().trim();
            if (!text.isEmpty()) {
                chat.messages.add(new Message("me", text, "Just now", false));
                adapter.notifyItemInserted(chat.messages.size() - 1);
                rvMessages.scrollToPosition(chat.messages.size() - 1);
                etMessageInput.setText("");

                // Trigger Simulated Smart Reply
                simulateReply(chat, adapter, rvMessages, tvTypingIndicator);
            }
        });

        fragmentContainer.addView(view);
    }

    private void simulateReply(Chat chat, MessagesAdapter adapter, RecyclerView rv, TextView typingIndicator) {
        typingIndicator.setVisibility(View.VISIBLE);
        typingIndicator.setText(chat.chatName + " is typing...");

        mainHandler.postDelayed(() -> {
            typingIndicator.setVisibility(View.GONE);
            String[] replies = {
                "That sounds amazing! Let's do it.",
                "I'm working on the premium dark theme right now.",
                "Can we jump on a quick video call?",
                "Got it! I will update the repository.",
                "ChatHub is looking incredibly polished! 🔥"
            };
            String randomReply = replies[new Random().nextInt(replies.length)];
            chat.messages.add(new Message("reply", randomReply, "Just now", true));
            adapter.notifyItemInserted(chat.messages.size() - 1);
            rv.scrollToPosition(chat.messages.size() - 1);
        }, 2500);
    }

    // --- VIDEO & VOICE CALL SYSTEM ---
    private void startVideoCall(String name, boolean isVideo) {
        Dialog callDialog = new Dialog(this, android.R.style.Theme_Black_NoTitleBar_Fullscreen);
        View view = LayoutInflater.from(this).inflate(R.layout.screen_video_call, null);
        callDialog.setContentView(view);

        TextView tvCallerName = view.findViewById(R.id.tv_call_name);
        TextView tvCallStatus = view.findViewById(R.id.tv_call_status);
        ImageView btnEndCall = view.findViewById(R.id.btn_end_call);
        ImageView ivCameraPreview = view.findViewById(R.id.iv_camera_preview);

        tvCallerName.setText(name);
        tvCallStatus.setText(isVideo ? "HD Video Call Connecting..." : "Voice Call Connecting...");

        if (!isVideo) {
            ivCameraPreview.setVisibility(View.GONE);
        }

        btnEndCall.setOnClickListener(v -> {
            callsList.add(0, new CallLog(name, "Outgoing", "Just now", isVideo, false));
            callDialog.dismiss();
        });

        callDialog.show();
    }

    // --- STATUS VIEWER ---
    private void showStatusViewer(StatusUpdate status) {
        Dialog statusDialog = new Dialog(this, android.R.style.Theme_Black_NoTitleBar_Fullscreen);
        View view = LayoutInflater.from(this).inflate(R.layout.screen_status_viewer, null);
        statusDialog.setContentView(view);

        TextView tvName = view.findViewById(R.id.tv_status_viewer_name);
        TextView tvContent = view.findViewById(R.id.tv_status_viewer_content);
        View progress = view.findViewById(R.id.status_progress_bar);

        tvName.setText(status.userName);
        tvContent.setText(status.statusText);

        // Animate progress bar
        progress.setScaleX(0);
        progress.animate().scaleX(1).setDuration(4000).setListener(new AnimatorListenerAdapter() {
            @Override
            public void onAnimationEnd(Animator animation) {
                statusDialog.dismiss();
            }
        }).start();

        statusDialog.show();
    }

